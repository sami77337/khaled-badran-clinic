# Dr. Khaled Badran Clinic environment template.
# Copy to .env for local use. Do not commit .env or real secrets.

# Django mode and secrets
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=replace-with-generated-secret
DJANGO_DEBUG=true
DJANGO_PRODUCTION=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=

# Locale
TIME_ZONE=Asia/Amman
LANGUAGE_CODE=ar

# Database
# Local development: leave DATABASE_URL empty to use db.sqlite3.
# Production: use PostgreSQL, for example:
# DATABASE_URL=postgres://clinic_user:replace-with-db-password@db-host.example.com:5432/khaled_badran_clinic
DATABASE_URL=
DATABASE_CONN_MAX_AGE=0
DATABASE_CONN_HEALTH_CHECKS=false
DATABASE_SSL_REQUIRE=false

# Cache and booking rate limiting
# Local development: leave CACHE_URL empty to use LocMemCache.
# Production: use a shared cache such as Redis:
# CACHE_URL=redis://redis-host.example.com:6379/1
CACHE_URL=
DJANGO_CACHE_KEY_PREFIX=kbc

# HTTPS and secure cookies
# Production should set these explicitly through config.settings.prod.
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false

# Reverse proxy handling
# Enable SECURE_PROXY_SSL_HEADER only when a trusted reverse proxy sets
# X-Forwarded-Proto=https for HTTPS requests.
DJANGO_SECURE_PROXY_SSL_HEADER_ENABLED=false
# Keep X-Forwarded-For untrusted unless the proxy strips client-supplied values.
BOOKING_TRUST_X_FORWARDED_FOR=false
BOOKING_TRUSTED_PROXY_CONFIGURED=false

# Logging and optional error reporting
DJANGO_LOG_LEVEL=INFO
SENTRY_DSN=

# Email placeholders for future production notifications.
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=

# Storage
MEDIA_PRIVATE_ROOT=media_private

# WhatsApp Business API placeholders only. No sending/webhooks exist yet.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
